# ============================================================
# ESAMIR - Environment Variables
# ============================================================
# Copy this file to .env.local for local development
# Copy this file to .env for production (Docker)
# ============================================================

# ----- DATABASE -----
DATABASE_URL="postgresql://esamir:esamir_pass@localhost:5432/esamir_db"

# ----- NEXTAUTH -----
NEXTAUTH_SECRET="change-this-to-a-long-random-string-at-least-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# ----- ADMIN DEFAULTS -----
ADMIN_EMAIL="admin@esamir.com"
ADMIN_PASSWORD="Admin123!"
ADMIN_NAME="ESAMIR Admin"

# ----- UPLOAD -----
UPLOAD_DIR="./public/uploads"
MAX_FILE_SIZE="10485760"

# ----- SITE -----
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="ESAMIR"
